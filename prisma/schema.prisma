generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum ArticleStatus {
  DRAFT
  PUBLISHED
  REJECTED
  ARCHIVED
}

enum ArticleSource {
  BOT
  MANUAL
}

model Article {
  id            String         @id @default(cuid())
  title         String
  slug          String         @unique
  meta          String
  keyword       String?
  category      String
  content       String
  imageUrl      String?
  source        String?
  status        ArticleStatus  @default(DRAFT)
  articleSource ArticleSource  @default(BOT)
  premium       Boolean        @default(false)
  duplicateOf   String?
  seoScore      Int?
  // AI üretimi okuyucu yardımcıları: { summary: string[], impact: string, faq: {q,a}[] }.
  // Eski makalelerde null kalır; sayfa null'da kutuyu/FAQ schema'yı gizler (graceful).
  aiExtras      Json?
  publishedAt   DateTime?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  @@index([category, status])
  @@index([status, publishedAt(sort: Desc)])
}

model AdminUser {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  name      String?
  createdAt DateTime @default(now())
}

model SiteSettings {
  id    String @id @default("singleton")
  value Json   @default("{}")
}

model BreakingNews {
  id        String    @id @default(cuid())
  text      String
  url       String?
  active    Boolean   @default(true)
  expiresAt DateTime?
  createdAt DateTime  @default(now())
}

model Subscriber {
  id          String    @id @default(cuid())
  email       String    @unique
  active      Boolean   @default(true)
  // Hangi kategorilere abone (kripto/borsa/doviz/altin/ekonomi). Boş = tümü.
  preferences String[]  @default([])
  // Abonenin geldiği kaynak (ör. "site-form", "popup", "import")
  source      String?
  // Çift-onay (double opt-in): doğrulanana kadar bülten gönderilmez.
  confirmed   Boolean   @default(false)
  confirmedAt DateTime?
  createdAt   DateTime  @default(now())

  @@index([active, confirmed])
}

// A/B konu satırı testli bülten gönderimleri + açılma oranı takibi
model NewsletterCampaign {
  id           String   @id @default(cuid())
  segment      String?  // null = tüm aktif aboneler, aksi halde kategori
  subjectA     String
  subjectB     String?  // null ise A/B testi yok
  recipients   Int      @default(0)
  recipientsA  Int      @default(0)
  recipientsB  Int      @default(0)
  opensA       Int      @default(0)
  opensB       Int      @default(0)
  sentAt       DateTime @default(now())

  @@index([sentAt])
}

model PageView {
  id        String   @id @default(cuid())
  path      String
  createdAt DateTime @default(now())

  @@index([path, createdAt])
}

model BotRun {
  id                String    @id @default(cuid())
  startedAt         DateTime  @default(now())
  finishedAt        DateTime?
  articlesFound     Int       @default(0)
  articlesAdded     Int       @default(0)
  duplicatesSkipped Int       @default(0)
  errors            String?
  status            String    @default("running")
}
