# gelecekfinans-site — ortam değişkenleri örneği
# Gerçek değerler ASLA bu dosyaya yazılmaz. Prod sırları Vercel production env'inde tutulur:
#   npx vercel env add <VAR> production
# Lokal geliştirme için bu dosyayı .env olarak kopyalayıp doldur.

# --- Veritabanı (zorunlu) ---
DATABASE_URL="postgresql://user:pass@host/db?sslmode=require"   # Neon Postgres

# --- Auth (zorunlu) ---
NEXTAUTH_SECRET="openssl rand -base64 32 ile üret"
NEXTAUTH_URL="https://gelecekfinans.com"                        # lokalde http://localhost:3000

# --- OpenAI (zorunlu — makale botu) ---
OPENAI_API_KEY="sk-..."

# --- Cron & bot tetikleme sırları (zorunlu) ---
CRON_SECRET="rastgele uzun string"        # Vercel cron'ları bunu Bearer olarak gönderir (/api/bot/cron, /api/newsletter/cron)
BOT_SECRET="rastgele uzun string"         # admin panelinden elle bot tetikleme
NEWSLETTER_SECRET="rastgele uzun string"  # newsletter işlemleri

# --- E-posta (newsletter — zorunlu) ---
RESEND_API_KEY="re_..."
MAIL_FROM="GelecekFinans <bulten@gelecekfinans.com>"

# --- Site & medya ---
SITE_URL="https://gelecekfinans.com"
BLOB_READ_WRITE_TOKEN="vercel_blob_rw_..."   # Vercel Blob (görsel yükleme)
UNSPLASH_ACCESS_KEY=""                        # opsiyonel — makale görseli fallback

# --- Ayarlar (opsiyonel) ---
BREAKING_NEWS_TTL_HOURS="24"                  # son dakika banner ömrü (saat)

# Not: GA4 / Search Console env değişkeni YOK — admin panelinden DB'de (SiteSettings) yönetilir.
